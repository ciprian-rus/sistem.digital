{
  "name": "@sistem-digital/tokens",
  "version": "0.1.0-alpha.0",
  "description": "Design tokens canonice pentru Sistem Digital.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://sistem.digital",
  "repository": {
    "type": "git",
    "url": "https://github.com/ciprian-rus/sistem.digital.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/ciprian-rus/sistem.digital/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src/tokens.css",
    "src/tokens.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./src/tokens.css",
    "./tokens.json": "./src/tokens.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
