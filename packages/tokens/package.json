{
  "name": "@sistem-digital/tokens",
  "version": "0.1.0-alpha.0",
  "description": "Design tokens canonice pentru Sistem Digital.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://sistem.digital",
  "repository": {
    "type": "git",
    "url": "https://github.com/ciprian-rus/sistem.digital.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/ciprian-rus/sistem.digital/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src/tokens.css",
    "src/tokens.json",
    "src/tokens.dtcg.json",
    "tokens",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./src/tokens.css",
    "./tokens.json": "./src/tokens.json",
    "./tokens.dtcg.json": "./src/tokens.dtcg.json",
    "./source/manifest.json": "./tokens/manifest.json",
    "./source/core.tokens.json": "./tokens/core.tokens.json",
    "./source/semantic.tokens.json": "./tokens/semantic.tokens.json",
    "./source/component.tokens.json": "./tokens/component.tokens.json"
  },
  "scripts": {
    "tokens:generate": "node scripts/build-tokens.mjs",
    "tokens:check": "node scripts/build-tokens.mjs --check",
    "build": "pnpm tokens:generate && tsc -p tsconfig.json",
    "lint": "pnpm tokens:check && eslint src scripts",
    "typecheck": "pnpm tokens:check && tsc -p tsconfig.json --noEmit",
    "test": "pnpm tokens:check && vitest run",
    "prepack": "pnpm build"
  }
}
