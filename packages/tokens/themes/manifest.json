{
  "format": "Sistem Digital Themes 1.0",
  "storageKey": "sd-theme",
  "defaultTheme": "light",
  "autoDarkTheme": "dark",
  "themes": [
    {
      "name": "light",
      "label": "Luminos",
      "source": "light.theme.json",
      "selector": ":root, [data-sd-theme=\"light\"]",
      "colorScheme": "light"
    },
    {
      "name": "dark",
      "label": "Întunecat",
      "source": "dark.theme.json",
      "selector": "[data-sd-theme=\"dark\"]",
      "colorScheme": "dark"
    },
    {
      "name": "high-contrast-light",
      "label": "Contrast ridicat luminos",
      "source": "high-contrast-light.theme.json",
      "selector": "[data-sd-theme=\"high-contrast-light\"]",
      "colorScheme": "light"
    },
    {
      "name": "high-contrast-dark",
      "label": "Contrast ridicat întunecat",
      "source": "high-contrast-dark.theme.json",
      "selector": "[data-sd-theme=\"high-contrast-dark\"]",
      "colorScheme": "dark"
    }
  ],
  "requiredRoles": [
    "brand.default",
    "brand.strong",
    "brand.subtle",
    "text.default",
    "text.muted",
    "text.inverse",
    "text.disabled",
    "surface.page",
    "surface.subtle",
    "surface.raised",
    "surface.strong",
    "border.default",
    "border.strong",
    "border.disabled",
    "link.default",
    "link.hover",
    "link.active",
    "link.visited",
    "action.primary.background",
    "action.primary.text",
    "action.primary.hover",
    "action.primary.active",
    "action.primary.disabledBackground",
    "action.primary.disabledText",
    "feedback.info.text",
    "feedback.info.background",
    "feedback.info.border",
    "feedback.success.text",
    "feedback.success.background",
    "feedback.success.border",
    "feedback.warning.text",
    "feedback.warning.background",
    "feedback.warning.border",
    "feedback.danger.text",
    "feedback.danger.background",
    "feedback.danger.border",
    "focus.ring",
    "focus.contrast"
  ],
  "contrastPairs": [
    { "foreground": "text.default", "background": "surface.page", "minimum": 7 },
    { "foreground": "text.muted", "background": "surface.page", "minimum": 4.5 },
    { "foreground": "text.disabled", "background": "surface.page", "minimum": 4.5 },
    { "foreground": "text.inverse", "background": "surface.strong", "minimum": 4.5 },
    { "foreground": "link.default", "background": "surface.page", "minimum": 4.5 },
    { "foreground": "link.hover", "background": "surface.page", "minimum": 4.5 },
    { "foreground": "link.active", "background": "surface.page", "minimum": 4.5 },
    { "foreground": "link.visited", "background": "surface.page", "minimum": 4.5 },
    {
      "foreground": "action.primary.text",
      "background": "action.primary.background",
      "minimum": 4.5
    },
    { "foreground": "action.primary.text", "background": "action.primary.hover", "minimum": 4.5 },
    { "foreground": "action.primary.text", "background": "action.primary.active", "minimum": 4.5 },
    {
      "foreground": "action.primary.disabledText",
      "background": "action.primary.disabledBackground",
      "minimum": 4.5
    },
    {
      "foreground": "feedback.info.text",
      "background": "feedback.info.background",
      "minimum": 4.5
    },
    {
      "foreground": "feedback.success.text",
      "background": "feedback.success.background",
      "minimum": 4.5
    },
    {
      "foreground": "feedback.warning.text",
      "background": "feedback.warning.background",
      "minimum": 4.5
    },
    {
      "foreground": "feedback.danger.text",
      "background": "feedback.danger.background",
      "minimum": 4.5
    },
    { "foreground": "focus.ring", "background": "surface.strong", "minimum": 3 },
    { "foreground": "focus.contrast", "background": "surface.page", "minimum": 3 }
  ]
}
