{
  "$description": "Valori primitive. Nu se consumă direct în componentele de produs.",
  "core": {
    "$description": "Valori primitive. Nu se consumă direct în componentele de produs.",
    "color": {
      "$type": "color",
      "blue": {
        "900": { "$value": { "colorSpace": "srgb", "components": [0, 0.164706, 0.34902], "hex": "#002a59" } },
        "700": { "$value": { "colorSpace": "srgb", "components": [0, 0.294118, 0.509804], "hex": "#004b82" } },
        "600": { "$value": { "colorSpace": "srgb", "components": [0.113725, 0.47451, 0.74902], "hex": "#1d79bf" } },
        "100": { "$value": { "colorSpace": "srgb", "components": [0.909804, 0.94902, 0.980392], "hex": "#e8f2fa" } }
      },
      "neutral": {
        "1000": { "$value": { "colorSpace": "srgb", "components": [0.090196, 0.12549, 0.164706], "hex": "#17202a" } },
        "700": { "$value": { "colorSpace": "srgb", "components": [0.294118, 0.333333, 0.388235], "hex": "#4b5563" } },
        "500": { "$value": { "colorSpace": "srgb", "components": [0.419608, 0.447059, 0.501961], "hex": "#6b7280" } },
        "300": { "$value": { "colorSpace": "srgb", "components": [0.780392, 0.803922, 0.831373], "hex": "#c7cdd4" } },
        "100": { "$value": { "colorSpace": "srgb", "components": [0.960784, 0.968627, 0.980392], "hex": "#f5f7fa" } },
        "0": { "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "hex": "#ffffff" } }
      },
      "cyan": {
        "700": { "$value": { "colorSpace": "srgb", "components": [0, 0.368627, 0.658824], "hex": "#005ea8" } }
      },
      "green": {
        "700": { "$value": { "colorSpace": "srgb", "components": [0, 0.439216, 0.235294], "hex": "#00703c" } }
      },
      "yellow": {
        "500": { "$value": { "colorSpace": "srgb", "components": [0.952941, 0.713725, 0.121569], "hex": "#f3b61f" } },
        "400": { "$value": { "colorSpace": "srgb", "components": [1, 0.74902, 0.278431], "hex": "#ffbf47" } }
      },
      "red": {
        "700": { "$value": { "colorSpace": "srgb", "components": [0.831373, 0.207843, 0.109804], "hex": "#d4351c" } }
      }
    },
    "dimension": {
      "$type": "dimension",
      "space": {
        "1": { "$value": { "value": 0.25, "unit": "rem" } },
        "2": { "$value": { "value": 0.5, "unit": "rem" } },
        "3": { "$value": { "value": 0.75, "unit": "rem" } },
        "4": { "$value": { "value": 1, "unit": "rem" } },
        "6": { "$value": { "value": 1.5, "unit": "rem" } },
        "8": { "$value": { "value": 2, "unit": "rem" } },
        "12": { "$value": { "value": 3, "unit": "rem" } },
        "16": { "$value": { "value": 4, "unit": "rem" } }
      },
      "radius": {
        "control": { "$value": { "value": 0.25, "unit": "rem" } },
        "panel": { "$value": { "value": 0.5, "unit": "rem" } }
      },
      "layout": {
        "content": { "$value": { "value": 75, "unit": "rem" } },
        "reading": { "$value": { "value": 46, "unit": "rem" } }
      },
      "stroke": {
        "thin": { "$value": { "value": 1, "unit": "px" } },
        "medium": { "$value": { "value": 2, "unit": "px" } },
        "focus": { "$value": { "value": 0.25, "unit": "rem" } }
      },
      "target": {
        "minimum": { "$value": { "value": 2.75, "unit": "rem" } }
      }
    },
    "font": {
      "family": {
        "$type": "fontFamily",
        "sans": { "$value": ["Inter", "ui-sans-serif", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif"] },
        "mono": { "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "Monaco", "Consolas", "monospace"] }
      }
    },
    "duration": {
      "$type": "duration",
      "fast": { "$value": { "value": 100, "unit": "ms" } },
      "moderate": { "$value": { "value": 200, "unit": "ms" } },
      "slow": { "$value": { "value": 350, "unit": "ms" } }
    }
  }
}
