{
  "name": "@sistem-digital/components",
  "version": "0.1.0-alpha.0",
  "description": "Componente accesibile și independente de framework pentru Sistem Digital.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://sistem.digital/componente",
  "repository": {
    "type": "git",
    "url": "https://github.com/ciprian-rus/sistem.digital.git",
    "directory": "packages/components"
  },
  "bugs": {
    "url": "https://github.com/ciprian-rus/sistem.digital/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "dist-cjs",
    "src/forms.css",
    "src/navigation.css",
    "src/content.css",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "default": "./dist/index.js"
    },
    "./forms.css": "./src/forms.css",
    "./navigation.css": "./src/navigation.css",
    "./content.css": "./src/content.css"
  },
  "peerDependencies": {
    "@sistem-digital/tokens": ">=0.1.0-alpha.0 <1.0.0"
  },
  "scripts": {
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('node:fs').writeFileSync('dist-cjs/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "build": "pnpm build:esm && pnpm build:cjs",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.cjs.json --noEmit",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@sistem-digital/tokens": "workspace:*",
    "vitest": "catalog:"
  }
}
