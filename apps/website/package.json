{
  "name": "@sistem-digital/website",
  "version": "0.1.0-alpha.0",
  "private": true,
  "scripts": {
    "build": "next build && node scripts/check-performance-budget.mjs",
    "dev": "next dev --turbopack",
    "lint": "eslint src tests playwright.config.ts playwright.visual.config.ts vitest.config.ts",
    "start": "next start",
    "test": "vitest run --config vitest.config.ts",
    "test:a11y": "playwright test --config=playwright.config.ts",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "performance:check": "node scripts/check-performance-budget.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sistem-digital/components": "workspace:*",
    "@sistem-digital/tokens": "workspace:*",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@mdx-js/loader": "catalog:",
    "@mdx-js/react": "catalog:",
    "@next/mdx": "catalog:",
    "@playwright/test": "catalog:",
    "@types/mdx": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "remark-frontmatter": "catalog:",
    "remark-mdx-frontmatter": "catalog:",
    "vitest": "catalog:"
  }
}
